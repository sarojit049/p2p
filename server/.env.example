# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=development
PORT=5000
APP_NAME=PrivateConnect

# ==========================================
# FRONTEND
# ==========================================
CLIENT_URL=http://localhost:5173

# ==========================================
# DATABASE
# ==========================================
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/privateconnect

# ==========================================
# JWT
# ==========================================
JWT_SECRET=replace_with_a_long_random_secret_of_at_least_32_chars
JWT_EXPIRES_IN=24h

# ==========================================
# ADMIN
# ==========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_secure_password_min_12_chars

# ==========================================
# SOCKET
# ==========================================
SOCKET_CORS_ORIGIN=http://localhost:5173

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
